# =============================================================================
# NovaStream - Environment Configuration
# =============================================================================
# IMPORTANT: Copy this file to the project root as `.env` and fill in values.
# The `.env` file is listed in `.gitignore` — NEVER commit it to version control.
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/novastream
# Atlas: mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/novastream
MONGODB_URI=mongodb://localhost:27017/novastream

# ─── TMDB API (The Movie Database) ──────────────────────────────────────────
# 🔐 REQUIRED: Register at https://www.themoviedb.org/settings/api to get these
#
# TMDB_API_KEY     = Your API Key (v3) — used for all metadata lookups
# TMDB_ACCESS_TOKEN = Your Bearer Token (v4) — optional but recommended
#                     for higher rate limits and more secure auth
#
# Where to find them:
#   1. Log in to themoviedb.org
#   2. Go to your Profile icon → Settings → API
#   3. You'll see both the "API Key (v3)" and "API Read Access Token (v4)"

TMDB_API_KEY=your_tmdb_api_key_here
TMDB_ACCESS_TOKEN=your_tmdb_access_token_here
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p/

# ─── JWT Authentication ──────────────────────────────────────────────────────
# Generate a strong random secret:
#   Windows:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   Mac/Linux: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─── Stream Security ─────────────────────────────────────────────────────────
# Secret key used to sign HLS stream URLs with HMAC-SHA256.
# Generate the same way as JWT_SECRET.
STREAM_SECRET=your_stream_secret_here
STREAM_TOKEN_EXPIRY_HOURS=24

# ─── Rate Limiting (optional) ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000        # 15 min window
RATE_LIMIT_MAX=100                 # General API max requests
AUTH_RATE_LIMIT_MAX=5              # Login attempts per window
STREAM_RATE_LIMIT_MAX=30           # Stream requests per window
