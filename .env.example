# ═══════════════════════════════════════════════════════════════
# NovaStream — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Three environment modes are supported:
#   development — local dev (default)
#   staging     — pre-production testing
#   production  — live deployment
#
# Required for all environments: TMDB_API_KEY, TMDB_ACCESS_TOKEN,
# MONGODB_URI, JWT_SECRET, STREAM_SECRET
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
#  SERVER
# ───────────────────────────────────────────────────────────────

# Application environment (development, staging, production)
#   development → verbose logs, hot reload, direct HLS access
#   staging     → production-like with debug info
#   production  → minimal logs, security hardened, compressed assets
NODE_ENV=development

# Server port (must be unique per environment)
PORT=5000

# Client URL (for CORS in production, e.g. https://novastream.example.com)
# Leave empty in development (uses localhost:5173 defaults)
CLIENT_URL=

# Log level (trace, debug, info, warn, error, fatal)
#   development → debug
#   staging     → info
#   production  → warn
LOG_LEVEL=info

# ───────────────────────────────────────────────────────────────
#  DATABASE (MongoDB)
# ───────────────────────────────────────────────────────────────

# MongoDB connection string
#   Local:  mongodb://localhost:27017/novastream
#   Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/novastream
#   Docker: mongodb://mongodb:27017/novastream
MONGODB_URI=mongodb://localhost:27017/novastream

# ───────────────────────────────────────────────────────────────
#  JWT AUTHENTICATION
# ───────────────────────────────────────────────────────────────

# JWT signing secret (minimum 32 characters)
# Generate: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-must-be-at-least-32-characters-long

# Token expiry duration (e.g. 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# ───────────────────────────────────────────────────────────────
#  STREAM SECURITY (HLS)
# ───────────────────────────────────────────────────────────────

# Stream token signing secret (minimum 32 characters)
# Generate: openssl rand -hex 32
STREAM_SECRET=your-stream-secret-must-be-at-least-32-characters-long

# Stream token expiry in hours
STREAM_TOKEN_EXPIRY_HOURS=24

# ───────────────────────────────────────────────────────────────
#  TMDB (Content Metadata)
# ───────────────────────────────────────────────────────────────

# TMDB API v3 key (from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your-tmdb-api-key

# TMDB API v4 access token (JWT from TMDB API settings)
TMDB_ACCESS_TOKEN=your-tmdb-access-token

# TMDB image base URL (only change if TMDB changes their CDN)
TMDB_IMAGE_BASE=https://image.tmdb.org/t/p/

# ───────────────────────────────────────────────────────────────
#  STORAGE
# ───────────────────────────────────────────────────────────────

# Upload directory path (relative or absolute)
UPLOAD_PATH=server/uploads

# ───────────────────────────────────────────────────────────────
#  RATE LIMITING
# ───────────────────────────────────────────────────────────────

# General API: requests per 15-minute window
RATE_LIMIT_MAX=100

# Auth endpoint: login attempts per 1-minute window
AUTH_RATE_LIMIT_MAX=5

# Stream endpoint: requests per 1-minute window
STREAM_RATE_LIMIT_MAX=30

# ───────────────────────────────────────────────────────────────
#  STAGING / PRODUCTION OVERRIDES
# ───────────────────────────────────────────────────────────────
#
# When NODE_ENV=production, these settings take effect:
#   - Compression enabled on static assets
#   - Dev-only routes (/hls) disabled
#   - Verbose error details hidden
#   - Helmet CSP upgrade-insecure-requests enabled
#   - CORS restricted to CLIENT_URL
#   - Cache-Control max-age set to 1 year for assets
#
# When NODE_ENV=staging, these settings take effect:
#   - Production-like behavior
#   - Debug-level logging still available
#   - Useful for pre-deployment testing
