# ═══════════════════════════════════════════════════════════════
# NovaStream — .dockerignore
# ═══════════════════════════════════════════════════════════════

# Node
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
.pnpm-store/

# Env
.env
.env.local
.env.production

# Build artifacts
client/dist/
client/build/
server/dist/
server/build/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.idea/
.vscode/
*.iml
*.sublime-*

# Git
.git/
.gitignore
.gitattributes

# Docker (don't copy Docker files into the build)
docker/
Dockerfile
docker-compose*.yml
.dockerignore

# Test
test/
coverage/
__tests__/

# Temp
uploads/
thumbnails/
media/
tmp/
temp/

# Documentation
docs/
README.md
GOVERNANCE.md

# Scripts
scripts/
install.sh
install.ps1
requirements.txt

# CLI (not used inside container — server manages itself)
cli/
