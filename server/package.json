    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.1",
    "express-slow-down": "^2.0.3",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "moviedb-promise": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
